# database
DB_NAME=
DB_USER=
DB_PASSWORD=

# google cloud (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback
GOOGLE_YOUTUBE_REDIRECT_URL=http://localhost:8080/auth/youtube/callback
GOOGLE_IOS_CLIENT_ID=

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=

# Nginx config — select environment:
#   local:      ./docker/nginx/local.conf        (HTTP, localhost)
#   production: ./docker/nginx/production.conf   (HTTPS, DuckDNS + certbot)
NGINX_CONF_FILE=./docker/nginx/local.conf

# HTTP port exposed on the host (local: 8080 to avoid Herd; production: 80)
HTTP_PORT=8080
